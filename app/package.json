{
  "name": "vigla-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:webdemo": "tsc -b && vite build --mode webdemo --outDir dist-webdemo",
    "site:build": "pnpm build:webdemo && node ../scripts/build-site.mjs",
    "site:check": "node ../scripts/build-site.mjs --check",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "vitest",
    "e2e": "node ../tests/e2e/run-playwright.cjs test -c ../tests/e2e/playwright.config.ts",
    "e2e:webdemo": "node ../tests/e2e/run-playwright.cjs --web-demo test -c ../tests/e2e/playwright.config.ts web-demo.spec.ts",
    "e2e:site": "pnpm site:build && node ../tests/e2e/run-playwright.cjs --site test -c ../tests/e2e/playwright.config.ts site.spec.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "terser": "^5.48.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.0"
  }
}
