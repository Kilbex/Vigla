{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vigla",
  "version": "0.1.0",
  "identifier": "dev.vigla.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vigla",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "base-uri": "'none'",
        "connect-src": "ipc: http://ipc.localhost",
        "font-src": "'self' data:",
        "form-action": "'none'",
        "img-src": "'self' data: blob:",
        "object-src": "'none'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'"
      },
      "devCsp": {
        "default-src": "'self'",
        "base-uri": "'none'",
        "connect-src": "'self' ipc: http://ipc.localhost ws://localhost:1420",
        "font-src": "'self' data:",
        "form-action": "'none'",
        "img-src": "'self' data: blob:",
        "object-src": "'none'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "resources": {
      "../../target/release/mock-harness": "mock-harness"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Mission control for your AI roster",
    "longDescription": "Vigla is a macOS desktop app that launches, supervises, and visualizes external AI coding CLIs (Claude CLI, Codex CLI, ...) as a named, visible workforce in an operations-room UI. Local-first, vendor-neutral, demo without an API key.",
    "macOS": {
      "minimumSystemVersion": "12.0",
      "frameworks": [],
      "exceptionDomain": "",
      "signingIdentity": null,
      "providerShortName": null,
      "entitlements": "Entitlements.plist",
      "hardenedRuntime": true,
      "dmg": {
        "background": null,
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    }
  }
}
