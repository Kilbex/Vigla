{
  "schema_version": 1,
  "id": "antigravity",
  "display_name": "Antigravity CLI",
  "cli_binary": "agy",
  "adapter_crate": "adapters/antigravity",
  "commands": {
    "supervisor": {
      "supported": false,
      "args": []
    },
    "mission_worker": {
      "supported": true,
      "args": [
        "--dangerously-skip-permissions",
        "--add-dir",
        "${cwd}",
        "${model_args}",
        "-p",
        "${prompt}"
      ]
    },
    "standalone_worker": {
      "supported": true,
      "args": [
        "--dangerously-skip-permissions",
        "--add-dir",
        "${cwd}",
        "${model_args}",
        "-p",
        "${prompt}"
      ]
    }
  },
  "declared_side_effects": [
    {
      "kind": "paid_api_call",
      "mode": "expected",
      "description": "Antigravity CLI calls its hosted inference service for normal operation."
    },
    {
      "kind": "network_egress",
      "mode": "expected",
      "description": "Antigravity CLI communicates with hosted services and may use networked commands when the task explicitly requires it."
    },
    {
      "kind": "package_install",
      "mode": "possible",
      "description": "Workers may install packages only when the assigned task explicitly requires it."
    },
    {
      "kind": "external_mutation",
      "mode": "possible",
      "description": "Workers may mutate external systems only through commands the task explicitly asks for; Vigla records this as visible, not reversible, authority."
    }
  ]
}
