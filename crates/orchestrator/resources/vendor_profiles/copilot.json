{
  "schema_version": 1,
  "id": "copilot",
  "display_name": "GitHub Copilot CLI",
  "cli_binary": "copilot",
  "adapter_crate": "adapters/copilot",
  "commands": {
    "supervisor": {
      "supported": false,
      "args": []
    },
    "mission_worker": {
      "supported": true,
      "args": [
        "--allow-all",
        "--no-ask-user",
        "-C",
        "${cwd}",
        "--output-format",
        "json",
        "-s",
        "${model_args}",
        "-p",
        "${prompt}"
      ]
    },
    "standalone_worker": {
      "supported": true,
      "args": [
        "--allow-all",
        "--no-ask-user",
        "-C",
        "${cwd}",
        "--output-format",
        "json",
        "-s",
        "${model_args}",
        "-p",
        "${prompt}"
      ]
    }
  },
  "declared_side_effects": [
    {
      "kind": "paid_api_call",
      "mode": "expected",
      "description": "GitHub Copilot CLI calls GitHub's hosted inference service for normal operation."
    },
    {
      "kind": "network_egress",
      "mode": "expected",
      "description": "GitHub Copilot CLI communicates with GitHub services and may use networked commands when the task explicitly requires it."
    },
    {
      "kind": "package_install",
      "mode": "possible",
      "description": "Workers may install packages only when the assigned task explicitly requires it."
    },
    {
      "kind": "external_mutation",
      "mode": "possible",
      "description": "Workers may mutate external systems only through commands the task explicitly asks for; Vigla records this as visible, not reversible, authority."
    }
  ]
}
